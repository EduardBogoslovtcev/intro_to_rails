<!DOCTYPE html>
<html>
  <head>
    <title>IntroProject</title>
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <style>
      body {
        font-family: Arial;
        background: white;
        color: black;
        margin: 0;
      }

      header {
        background: #eee;
        padding: 10px;
        border-bottom: 1px solid #ccc;
      }

      nav a {
        margin-right: 15px;
        color: black;
        text-decoration: none;
        font-weight: bold;
      }

      nav a:hover {
        text-decoration: underline;
      }

      .container {
        padding: 20px;
      }
    </style>
  </head>

  <body>
    <header>
      <nav>
        <%= link_to "Recipes", recipes_path %>
        <%= link_to "Users", users_path %>
        <%= link_to "Ingredients", ingredients_path %>
        <%= link_to "About", about_path %>
      </nav>
    </header>

    <div class="container">
      <%= yield %>
    </div>
  </body>
</html>